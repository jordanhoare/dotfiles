# Claude
.claude/settings.local.json
home/.claude/*
!home/.claude/settings.json
!home/.claude/CLAUDE.md
!home/.claude/skills/

# SSH
home/.ssh/*
!home/.ssh/config

# Git
config/git/private

# macOS
home/.DS_Store

# AWS
home/.aws/credentials

# gcloud - only properties is portable; everything else is auth/machine state
config/gcloud/*
!config/gcloud/properties

# Azure
home/.azure/accessTokens.json
home/.azure/msal_token_cache.json
home/.azure/azureProfile.json
home/.azure/clouds.config

# gh / glab - hosts files contain auth tokens
config/gh/hosts.yml
config/glab-cli/hosts.yml
