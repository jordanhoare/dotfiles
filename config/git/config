[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[user]
  name = Jordan Hoare
  email = jordanhoare0@gmail.com
  username = jordanhoare

[core]
  editor = code --wait
  preloadindex = true
  fscache = true
  autocrlf = input
  trustctime = false
  ignorecase = false

[init]
  defaultBranch = main

[branch]
  autosetuprebase = always

[pull]
  rebase = true

[push]
  default = current
  autoSetupRemote = true

[alias]
  personal = "!git config user.name 'jordanhoare' && git config user.email 'jordanhoare0@gmail.com' && gh auth switch --user jordanhoare"
  private = "!git config user.name \"$(git config --file ~/.config/git/private user.name)\" && git config user.email \"$(git config --file ~/.config/git/private user.email)\" && gh auth switch --user \"$(git config --file ~/.config/git/private github.user)\""
  whoami = "!echo \"$(git config user.name) <$(git config user.email)>\""

[safe]
	directory = *

# Optimize git for all Windows mounts (/mnt/*) - these are extremely slow
# This applies to all repos on Windows filesystems accessed from WSL
[includeIf "gitdir:/mnt/"]
  [core]
    # This prevents git from checking file permissions on every operation
    fileMode = false
  [status]
    aheadBehind = false
    showUntrackedFiles = normal

[commit]
  gpgSign = false
[fetch]
	tags = true
	fsckObjects = false
	writeCommitGraph = true
[status]
	submoduleSummary = false
	showUntrackedFiles = normal
	aheadBehind = false
[feature]
	manyFiles = true
[remote "origin"]
	tagOpt = --force
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[includeIf "gitdir:/mnt/d/repositories/private/"]
  path = ~/.config/git/private
