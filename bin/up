#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$(cd "$(dirname "$0")/.." && pwd)"

echo "==> nix"
nix flake update --flake "$DOTFILES/nix"
make -C "$DOTFILES" switch

if command -v sheldon &>/dev/null; then
  echo "==> sheldon"
  sheldon lock --update
fi

if command -v mise &>/dev/null; then
  echo "==> mise"
  mise upgrade
fi

if command -v uv &>/dev/null; then
  echo "==> uv global tools"
  uv tool upgrade --all
fi

echo "==> done"
