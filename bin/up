#!/usr/bin/env bash
set -euo pipefail

if command -v brew &>/dev/null; then
  echo "==> brew"
  brew update && brew upgrade && brew cleanup
fi

if command -v apt-get &>/dev/null; then
  echo "==> apt"
  sudo apt-get update && sudo apt-get upgrade -y && sudo apt-get autoremove -y
fi

if command -v sheldon &>/dev/null; then
  echo "==> sheldon"
  sheldon lock --update
fi

if command -v uv &>/dev/null; then
  echo "==> uv tools"
  uv tool upgrade --all
fi

if command -v bun &>/dev/null; then
  echo "==> bun"
  if ! bun upgrade; then
    curl -fsSL https://bun.sh/install | bash
    # the installer appends a completions block to ~/.zshrc — strip it since
    # we already source completions portably via $BUN_INSTALL in .zshrc
    sed -i '' '/# bun completions/,/source.*_bun/d' ~/.zshrc
  fi
fi

echo "==> done"
