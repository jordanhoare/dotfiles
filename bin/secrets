#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$(cd "$(dirname "$0")/.." && pwd)"

if ! bw login --check 2>/dev/null; then
    bw login
fi

BW_SESSION=$(bw unlock --raw)
mkdir -p ~/.ssh

ID=$(bw list items --search "personal" --session "$BW_SESSION" | jq -r '.[] | select(.type == 5) | .id')
bw get item "$ID" --session "$BW_SESSION" | jq -r '.sshKey.privateKey' > ~/.ssh/personal

ID=$(bw list items --search "private" --session "$BW_SESSION" | jq -r '.[] | select(.type == 5) | .id')
bw get item "$ID" --session "$BW_SESSION" | jq -r '.sshKey.privateKey' > ~/.ssh/private

chmod 600 ~/.ssh/personal ~/.ssh/private
SOPS_AGE_SSH_PRIVATE_KEY_FILE=~/.ssh/personal sops --decrypt --output "$DOTFILES/config/git/private" "$DOTFILES/config/git/private.enc"
bw lock
